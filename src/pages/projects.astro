---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---
<BaseLayout title="案例作品" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-2">案例作品</div>
    <div class="mb-5 text-lg">从品牌策略到落地执行，以下是我主导或参与的代表性项目。</div>
  </div>
  <HorizontalCard title="金融行业首个系统性体育营销计划" img="/post_img.webp" desc="牵头整合篮球（CBA、NYBO）、足球（东北超、滇超）、极限运动（环塔拉力赛、登珠峰）等多元赛事资源，以「大众运动」与「态度营销」为核心，线上话题与线下活动双轮驱动。累计触达超 1000 万人次，荣获「燕梳奖·卓越品牌营销奖」，为公司 APP 引流超 126 万人次。" url="#" badge="获奖项目" />
  <div class="divider my-0"></div>
  <HorizontalCard title="北京环球度假区官方保险合作 · 中国人寿环球品牌日" img="/post_img.webp" desc="作为北京环球度假区官方保险合作伙伴，主导「中国人寿环球品牌日」落地，冠名「变形金刚」基地并打造「国寿机器人」标志性形象；借力小黄人、变形金刚等顶级 IP 对保险产品进行场景化包装。累计提供保额超 700 亿元，实现品牌曝光与产品转化的有效联动。" url="#" badge="IP 合作" />
  <div class="divider my-0"></div>
  <HorizontalCard title="「国寿好服务」子品牌 0 到 1 建设" img="/post_img.webp" desc="制定子品牌定位与推广策略，通过构建视觉资产体系、策划电视节目、推出创意广告等多元形式深耕垂类传播，累计曝光超 5 亿人次，有效提升消费者品牌感知力与好感度。" url="#" />
  <div><div class="text-3xl w-full font-bold mb-5 mt-10">更多项目</div></div>
  <HorizontalCard title="CBA 联赛权益激活 · 品销一体化" img="/post_img.webp" desc="统筹全明星周末、少年 CBA、俱乐部探营及扣篮大赛等系列活动，覆盖多元场景。品牌侧实现高频次规模化曝光，业务侧每年间接拉动收入超 6000 万元。" url="#" />
  <div class="divider my-0"></div>
  <HorizontalCard title="品牌年轻化转型 · 多平台社媒运营" img="/post_img.webp" desc="微信视频号达行业排名 Top1，小红书涨粉速度达同业 5 倍，年轻用户互动率 60%，全平台舆论健康度同比提升 11%。" url="#" />
  <div class="divider my-0"></div>
  <HorizontalCard title="重要节点品牌内容制作" img="/post_img.webp" desc="主导公益宣传片、企业微电影、司庆海报等重要宣传物料制作发布，多形态产出超 100 份物料，多次荣获 IAI 传鉴国际广告奖、麒麟国际广告奖、中国创新传播大奖蒲公英。" url="#" badge="获奖项目" />
</BaseLayout>
